# WFH Access Portal: Environment Configuration Template

# Flask session signing key 
FLASK_SECRET_KEY=production-secure-random-secret-key-here

# Run mode: 1 = local mock (no AWS/Nginx API calls), 0 = production mode
WFH_MOCK_ACCESS=1

# Server Metrics URL and Whitelisting API Key
SVRMETRICS_URL=http://localhost:6400
SVRMETRICS_API_KEY=svrmetrics-production-secret-api-key

# JWT Single Sign-On Secret for Server Metrics Dashboard
SSO_SECRET=sso-jwt-production-secret-token-key
